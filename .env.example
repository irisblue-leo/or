# Database
DATABASE_URL="postgresql://user:password@localhost:5432/openclaw_relay"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"

# Wallet Master Seed (IMPORTANT: Change in production!)
WALLET_MASTER_SEED="your-master-seed-change-in-production-keep-it-secret"

# ============================================
# Upstream API Configuration (REQUIRED)
# ============================================
# Primary upstream API (supports OpenAI-compatible models)
UPSTREAM_API_URL="https://hone.vvvv.ee/v1"
UPSTREAM_API_KEY="sk-your-api-key-here"

# OpenRouter API (for additional models)
OPENROUTER_API_URL="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY="sk-or-v1-your-key-here"
OPENROUTER_REFERER="https://openclaw-relay.com"

# Note: The system uses these environment variables for ALL traffic.
# Database Provider configs are for display only and not used for routing.

# ============================================
# Blockchain Monitor (Optional)
# ============================================
# Enable blockchain monitor (set to true to enable real-time deposit monitoring)
ENABLE_BLOCKCHAIN_MONITOR="true"

# RPC Endpoints (Optional, will use public RPCs if not set)
ETHEREUM_RPC="https://eth.llamarpc.com"
BSC_RPC="https://bsc-dataseed.binance.org"
POLYGON_RPC="https://polygon-rpc.com"
TRON_RPC="https://api.trongrid.io"
SOLANA_RPC="https://api.mainnet-beta.solana.com"

# Or use paid RPC services for better reliability:
# ETHEREUM_RPC="https://mainnet.infura.io/v3/YOUR_INFURA_KEY"
# BSC_RPC="https://bsc-dataseed1.binance.org"
# POLYGON_RPC="https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# ============================================
# Proxy Configuration (Optional)
# ============================================
# Proxy (if needed for OpenRouter or other services)
HTTP_PROXY="http://127.0.0.1:7890"
HTTPS_PROXY="http://127.0.0.1:7890"

# ============================================
# Email Configuration (Required for registration)
# ============================================
# SMTP邮件配置
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER="your-email@qq.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="your-email@qq.com"
